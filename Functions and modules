# Task1 
# Factorial: 5! = 5 x 4 x 3 x 2 x 1 = 120

num = int(input("Enter a number:"))

fact = 1
i = 1

while i <= num:
    fact = fact*i
    i = i + 1

print(f"factorial of {num} is: {fact}")

